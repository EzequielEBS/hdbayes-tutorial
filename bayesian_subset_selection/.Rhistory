# offset
population <- leish_data$pop
# LASSO
# create a model matrix
X <- model.matrix(n_cases ~ ., data = leish_data[vars])[,-1]
# fit the model
lasso <- cv.glmnet(x=X, y=leish_data$n_cases, type.measure="mse",
alpha=1, family="poisson", nlambda=200, offset=log(population))
best_lambda <- lasso$lambda.min
best_lambda
plot(lasso)
lasso_best <- glmnet(x=X,
y=leish_data$n_cases,
alpha=1,
family="poisson",
lambda=best_lambda,
offset=log(population))
coef(lasso_best)
# fit model with year
formula_glm_year <- as.formula(paste("n_cases ~ 1 + offset(log(population)) + year",
paste(vars, collapse = "+"), sep = "+"))
formula_inla_year <-
as.formula(paste("n_cases ~ 1 + offset(log(population)) + f(id, model = 'iid') + year",
paste(vars, collapse = "+"), sep = "+"))
nbin_glm_year <- glm.nb(formula_glm_year,
data = leish_data,
control = glm.control(maxit = 10000))
# fit model with year
formula_glm_year <- as.formula(paste("n_cases ~ 1 + offset(log(population)) + year",
paste(vars, collapse = "+"), sep = "+"))
formula_inla_year <-
as.formula(paste("n_cases ~ 1 + offset(log(population)) + f(id, model = 'iid') + year",
paste(vars, collapse = "+"), sep = "+"))
nbin_glm_year <- glm.nb(formula_glm_year,
data = leish_data,
control = glm.control(maxit = 10000))
nbin_inla_year <- inla(formula_inla_year,
data = leish_data,
family = "nbinomial",
control.predictor = list(compute = TRUE),
control.compute = list(dic = TRUE, waic = TRUE))
