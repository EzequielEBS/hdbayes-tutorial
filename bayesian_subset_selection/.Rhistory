library(tidyverse)
library(matrixStats)
# load data
data <- read_csv("data/chapman.csv")
# set parameters
ncores <- max(1, parallel::detectCores() - 2)
# load formulas
formulas <- readRDS("data/formulas.rds")
fit <- glm.post(formulas[[1]],
family = binomial(link = "logit"),
data = list(data),
parallel_chains = ncores,
iter_warmup = 2000,
iter_sampling = 2000,
refresh = 0,
)
# run hdbayes
fits <- lapply(formulas, function(x)
glm.post(x,
family = binomial(link = "logit"),
data = list(data),
parallel_chains = ncores,
iter_warmup = 2000,
iter_sampling = 2000,
refresh = 0,
))
# save results
saveRDS(fits, "results/fits_bayesian_model.rds")
# run glm
fits <- lapply(formulas, function(x)
glm(x, family = binomial(link = "logit"), data = data))
# save fits
saveRDS(fits, "results/fits_glm.rds")
install.packages("loo")
# load libraries
library(hdbayes)
library(lme4)
library(loo)
# load data
formulas <- readRDS("data/formulas.rds")
covariates_models <- readRDS("data/covariates_models.rds")
# load results
fits_bayesian_model <- readRDS("results/fits_bayesian_model.rds")
fits_glm <- readRDS("results/fits_glm.rds")
# compute marginal likelihood
marginal_likelihoods <- lapply(fits_bayesian_model, function(x) glm.logml.post(x)$logml)
# compute AIC
AICs <- lapply(fits_glm, function(x) x$aic)
# compute BIC
BICs <- lapply(fits_glm, function(x) BIC(x))
# create data frame
metrics <- data.frame(
variables = unlist(covariates_models),
logml = unlist(marginal_likelihoods),
AIC = unlist(AICs),
BIC = unlist(BICs)
)
# sort by logml
metrics <- metrics[order(metrics$logml, decreasing = TRUE), ]
# save results
saveRDS(metrics, "results/metrics.rds")
write.csv(metrics, "results/metrics.csv", row.names = FALSE)
# load libraries
library(matrixStats)
library(tidyverse)
# load data
metrics <- read_csv("results/metrics.csv")
# compute weights
weights_logml <- exp(unlist(metrics$logml) - logSumExp(unlist(metrics$logml)))
weights_AIC <- exp(unlist(-metrics$AIC) - logSumExp(unlist(-metrics$AIC)))
weights_BIC <- exp(unlist(-metrics$BIC) - logSumExp(unlist(-metrics$BIC)))
# create a data frame with the weights
weights <- data.frame(
variables = metrics$variables,
logml = weights_logml,
AIC = weights_AIC,
BIC = weights_BIC
)
# save the weights
write.csv(weights, "results/weights.csv", row.names = FALSE)
install.packages("viridis")
# load libraries
library(tidyverse)
library(ggplot2)
library(viridis)
# load data
metrics <- read_csv("results/metrics.csv")
weights <- read_csv("results/weights.csv")
head(weights)
library(reshape2)
# barplot of weights
weights_reshape <- melt(weights)
head(weights_reshape)
barplot_weights <- ggplot(weights_reshape, aes(x = variables, y = value)) +
geom_bar(stat = "identity", aes(fill = variable), position = "dodge") +
scale_fill_viridis(discrete = TRUE) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
barplot_weights
